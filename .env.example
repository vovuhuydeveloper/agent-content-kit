# ═══════════════════════════════════════════════════════════════
# Agent Content Kit — Configuration Template
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── LLM Provider (Required — pick ONE) ──────────────────────
# Options: openai | claude | gemini
LLM_PROVIDER=openai

# OpenAI (recommended for best results)
OPENAI_API_KEY=sk-your-key-here
# Get it: https://platform.openai.com/api-keys

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=
# Get it: https://console.anthropic.com/settings/keys

# Google Gemini (alternative)
GOOGLE_API_KEY=
# Get it: https://aistudio.google.com/apikey

# ── Media APIs ──────────────────────────────────────────────
# Pexels — Free stock video footage (Required for video creation)
PEXELS_API_KEY=
# Get it: https://www.pexels.com/api/ (free, instant)

# ElevenLabs — AI voice (Optional — falls back to free edge-tts)
ELEVENLABS_API_KEY=
# Get it: https://elevenlabs.io/

# ── Telegram Bot (Recommended — for review & approval) ──────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Setup: Open Telegram → @BotFather → /newbot → paste token
# Chat ID is auto-detected via Setup Wizard

# ── Brand (Optional) ───────────────────────────────────────
# Your brand name — shown on video thumbnails and overlays
BRAND_NAME=

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/autoclip.db

# ── Publishing ──────────────────────────────────────────────
# Auto-publishing uses browser session (Playwright + Chrome).
# No API keys needed — login via:
#   python -m backend.core.browser_session login youtube
#   python -m backend.core.browser_session login tiktok
#   python -m backend.core.browser_session login facebook
# Or use the Connect button on the dashboard.

# App base URL (for Telegram link buttons — only needed if deployed publicly)
# APP_BASE_URL=https://your-domain.com

# ── Advanced (Optional) ────────────────────────────────────
# Redis — Required only if using Celery workers
# REDIS_URL=redis://localhost:6379/0
